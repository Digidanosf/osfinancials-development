[INI]
Filename: {app}\tcash.ini; Section: Appconfig; Key: nounicode; String: {code:Getnounicode}

[Code]

// 1. Helper functions for parameter expansion
function Getnounicode(Param: String): string;
begin 
  Result := 'TRUE';
  if IsTaskSelected('unicode') then
    Result := 'FALSE';
end;

function Getaltfont(Param: String): string;
begin
  Result := 'FALSE';
  if IsTaskSelected('altfont') then
    Result := 'TRUE';
end;

// 2. The ONE AND ONLY NextButtonClick function
function NextButtonClick(CurPageID: Integer): Boolean;
var
  st1: string;
begin
  // Default to True so the wizard can continue moving forward
  Result := True;

  // UNICODE TASK VALIDATION LOGIC
  if CurPageID = wpSelectTasks then
  begin
    if not IsTaskSelected('checkedunicode') then
    begin
      MsgBox('Please check and confirm your unicode option.', mbError, MB_OK);
      Result := False; // Soft blocks the user from moving forward
      Exit;            // Exits early so it doesn't run the rest of the code on this page
    end;
  end;

  // 2. ORIGINAL TCASH5.EXE CLEANUP LOGIC
  if CurPageID > 3 then
  begin
    if FileExists(AddBackslash(ExpandConstant('{app}')) + 'TCASH5.exe') then
    begin
      st1 := AddBackslash(ExpandConstant('{app}')) + 'plug_ins\XMLAuditfileFinancial2.of4';
      if FileExists(st1) then DeleteFile(st1);

      st1 := AddBackslash(ExpandConstant('{app}')) + 'plug_ins\OfficePro.of4';
      if FileExists(st1) then DeleteFile(st1);

      st1 := AddBackslash(ExpandConstant('{app}')) + 'plug_ins\PINCTAP.of4';
      if FileExists(st1) then DeleteFile(st1);

      st1 := AddBackslash(ExpandConstant('{app}')) + 'plug_ins\DrivingSchool.of4';
      if FileExists(st1) then DeleteFile(st1);

      st1 := AddBackslash(ExpandConstant('{app}')) + 'plug_ins\Promeetec.of4';
      if FileExists(st1) then DeleteFile(st1);
    end;
  end;

  // 3. NEW REGISTERPLUGINS.OF3 CLEANUP LOGIC
  if CurPageID > 3 then
  begin
    if FileExists(AddBackslash(ExpandConstant('{app}')) + 'plug_ins\RegisterPlugins.of3') then
    begin
      DelTree(AddBackslash(ExpandConstant('{app}')) + 'plug_ins\*.of3', False, True, False);
    end;
  end;
end;