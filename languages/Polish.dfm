    item
      IndexID = 425
      Text = 
        'Ostrze'#380'enie! Ta operacja powa'#380'nie wp'#322'ynie na zbi'#243'r ksi'#261'g! Czy ch' +
        'cesz kontynuowa'#263'?'
    end
    item
      IndexID = 426
      Text = 
        'Zdecydowali Pa'#324'stwo o usuni'#281'ciu wszystkich u'#380'ytkownik'#243'w! Kontrol' +
        'a dost'#281'pu zostanie wy'#322#261'czona!'
    end
    item
      IndexID = 427
      Text = 
        'Istniej'#261' niezaksi'#281'gowane dzienniki powi'#261'zane z tym u'#380'ytkownikiem' +
        '! Prosz'#281' je zaksi'#281'gowa'#263' lub usun'#261#263' przed usuni'#281'ciem u'#380'ytkownika.'
    end
    item
      IndexID = 428
      Text = 
        'Istniej'#261' dzienniki powi'#261'zane z tym u'#380'ytkownikiem! Prosz'#281' wybra'#263' ' +
        'nowego u'#380'ytkownika, kt'#243'remu zostan'#261' one przypisane.'
    end
    item
      IndexID = 429
      Text = 
        'Istniej'#261' transakcje powi'#261'zane z tym u'#380'ytkownikiem! Prosz'#281' wybra'#263 +
        ' nowego u'#380'ytkownika, kt'#243'remu zostan'#261' one przypisane.'
    end
    item
      IndexID = 430
      Text = 'Czy chc'#261' Pa'#324'stwo zapisa'#263' zmiany dla tego u'#380'ytkownika?'
    end
    item
      IndexID = 431
      Text = 'Prosz'#281' wpisa'#263' has'#322'o dla tego u'#380'ytkownika!'
    end
    item
      IndexID = 432
      Text = 'Czy utworzy'#263' to konto?'
    end
    item
      IndexID = 433
      Text = 'Nieprawid'#322'owy numer konta! Pierwszym znakiem musi by'#263' cyfra!'
    end
    item
      IndexID = 434
      Text = 'To nie jest rachunek bankowy!'
    end
    item
      IndexID = 435
      Text = 'Czy chc'#261' Pa'#324'stwo zapisa'#263' zmiany?'
    end
    item
      IndexID = 436
      Text = '!!! KRYTYCZNY B'#321#260'D PLIKU 12 !!!'
    end
    item
      IndexID = 437
      Text = 'Czy na pewno chc'#261' Pa'#324'stwo usun'#261#263' t'#281' transakcj'#281'?'
    end
    item
      IndexID = 438
      Text = 'Czy chc'#261' Pa'#324'stwo przypisa'#263' t'#281' transakcj'#281' do ubieg'#322'ego roku?'
    end
    item
      IndexID = 439
      Text = 'Dziennik nie bilansuje si'#281'!'
    end
    item
      IndexID = 440
      Text = 'Konto nie istnieje, czy chc'#261' Pa'#324'stwo je utworzy'#263'?'
    end
    item
      IndexID = 441
      Text = 'Czy chc'#261' Pa'#324'stwo kontynuowa'#263' raportowanie?'
    end
    item
      IndexID = 442
      Text = 
        'Nie mo'#380'na usun'#261#263' tego typu dziennika! S'#261' z nim powi'#261'zane dzienni' +
        'ki!'
    end
    item
      IndexID = 443
      Text = 
        'Edycja typ'#243'w dziennik'#243'w powa'#380'nie wp'#322'ynie na zbi'#243'r ksi'#261'g! Czy na ' +
        'pewno chcesz to zrobi'#263'?'
    end
    item
      IndexID = 444
      Text = 'To powa'#380'nie wp'#322'ynie na zbi'#243'r ksi'#261'g! Czy chcesz teraz anulowa'#263'?'
    end
    item
      IndexID = 445
      Text = 'Czy chc'#261' Pa'#324'stwo zapisa'#263' te zmiany?'
    end
    item
      IndexID = 446
